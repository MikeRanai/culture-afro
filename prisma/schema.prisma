generator client {
  provider = "prisma-client"
  output   = "../src/app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  quote     String
  image     String   @default("")
  socialUrl String?
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("faq")
}

model SocialLink {
  id        String   @id @default(cuid())
  platform  String
  handle    String
  url       String
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Stat {
  id        String   @id @default(cuid())
  value     String
  label     String
  icon      String   @default("Users")
  color     String   @default("orange")
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Partner {
  id        String   @id @default(cuid())
  name      String
  logo      String
  url       String?
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminUser {
  id             String    @id @default(cuid())
  email          String    @unique
  passwordHash   String
  name           String
  loginAttempts  Int       @default(0)
  lockUntil      DateTime?
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model GalleryImage {
  id        String   @id @default(cuid())
  src       String
  alt       String
  legend    String   @default("")
  tall      Boolean  @default(false)
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DirectoryEntry {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  logo        String   @default("")
  url         String?
  category    String   @default("salons") // "salons" | "produits" | "partenaires_techniques"
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model HeroBanner {
  id          String   @id @default(cuid())
  image       String   @default("")
  subtitle    String   @default("")
  quote       String   @default("")
  ctaLabel1   String   @default("")
  ctaLink1    String   @default("")
  ctaLabel2   String   @default("")
  ctaLink2    String   @default("")
  decorWord   String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Pole {
  id          String   @id @default(cuid())
  surtitre    String   @default("")
  titre       String
  description String
  image       String   @default("")
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteSettings {
  id          String   @id @default(cuid())
  ogImage     String   @default("")
  ogTitle     String   @default("")
  ogDescription String @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ContactInfo {
  id        String   @id @default(cuid())
  type      String
  title     String
  value     String
  href      String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
